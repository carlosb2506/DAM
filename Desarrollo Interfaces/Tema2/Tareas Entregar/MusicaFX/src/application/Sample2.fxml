<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23" fx:controller="application.SampleController">

    <MenuBar>
        <Menu text="Archivo">
            <MenuItem accelerator="Ctrl+S" onAction="#handleSaveShortcut" text="Guardar" />
            <MenuItem text="Salir" />
        </Menu>
        <Menu text="Ayuda">
            <MenuItem onAction="#showAbout" text="Acerca de" />
        </Menu>
    </MenuBar>
    

    <AnchorPane fx:controller="application.Controlador" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">>
        <Button layoutX="20" layoutY="50" onAction="#nuevaVista" text="Nuevo Álbum" />
        <Button layoutX="120" layoutY="50" text="Nuevo Artista" />
        <Button layoutX="220" layoutY="50" text="Mostrar Canciones" />
    </AnchorPane>


    <AnchorPane>

        <VBox layoutX="50" layoutY="100">
            <Button text="Cargar Base de Datos" />
        </VBox>
    </AnchorPane>
</VBox>


