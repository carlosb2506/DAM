<?xml version="1.0" encoding="UTF-8"?>
	
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
	
<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.SampleController">
    <children>
        <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
            <children>
                <Label layoutX="28.0" layoutY="58.0" text="Id" />
                <Label layoutX="27.0" layoutY="96.0" text="Título" />
                <Label layoutX="24.0" layoutY="136.0" text="Artista" />
                <TextField fx:id="tfMatricula" layoutX="79.0" layoutY="54.0" />
                <TextField fx:id="tfMarca" layoutX="79.0" layoutY="92.0" />
                <ComboBox fx:id="cbTipo" layoutX="79.0" layoutY="131.0" prefHeight="27.0" prefWidth="167.0" />
                <TableView layoutX="17.0" layoutY="186.0" prefHeight="200.0" prefWidth="605.0">
                    <columns>
                        <TableColumn prefWidth="75.0" text="Id" />
                        <TableColumn prefWidth="349.0" text="Título" />
                        <TableColumn prefWidth="158.0" text="Artista" />
                    </columns>
                </TableView>
                <!-- Botón que llama al método nuevaVista cuando se hace clic -->
                <Button layoutX="269.0" layoutY="14.0" mnemonicParsing="false" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 1px;" text="Albúm" />
                <Button layoutX="320.0" layoutY="14.0" mnemonicParsing="false" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: black; -fx-border-width: 1px;" text="Artista" onAction="#nuevaVista"/>
            </children>
        </AnchorPane>
    </children>
</BorderPane>


